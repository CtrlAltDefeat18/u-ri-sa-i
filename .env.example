# Copy this to a file named .env for local running. Never commit the real .env.

# a long random string — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# the two of you. names are what you type at login.
USER1_NAME=you
USER1_PASS=pick-a-real-password
USER2_NAME=her
USER2_PASS=pick-a-real-password

# leave DATABASE_URL unset locally — it falls back to a SQLite file (us.db).
# in production, set it to your Postgres URL so data survives redeploys.
# DATABASE_URL=postgresql://...

# set this locally so cookies work over plain http on Cloud Shell:
FLASK_ENV=development
